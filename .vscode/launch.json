{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Api",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Api/bin/Debug/net10.0/Api.dll",
            "cwd": "${workspaceFolder}/Api",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on:\\s+(https?://\\S+)"
            }
        }
    ],
    "compounds": [
        {
            "name": "Api",
            "configurations": [
                "Api"
            ]
        }
    ]
}